        {
          "name": "Delete Expense",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/expenses/{{expense_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "expenses", "{{expense_id}}"]
            }
          },
          "response": []
