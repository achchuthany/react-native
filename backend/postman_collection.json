        {
          "name": "Get Expense Statistics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/expenses/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "expenses", "stats"]
            }
          },
          "response": []
        }
      ]
    },
    {
